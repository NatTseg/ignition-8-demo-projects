              "type": "property"
            }
          }
        },
        "props": {
          "alignVertical": "top",
          "style": {
            "fontSize": "12px",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\t# If this icon is not selected, then set selected to true and send a message to\n\t# the iconSelected handler, which will de-select the previously-selected icon and\n\t# update the icon on the \u0027select icon\u0027 popup.\n\t\n\tif not self.view.params.selected:\n\t\tself.custom.selected \u003d True\n\t\tsystem.perspective.sendMessage(\u0027iconSelected\u0027,payload\u003d{\u0027material\u0027:self.view.params.material},scope\u003d\u0027page\u0027)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "custom.selected": {
        "binding": {
          "config": {
            "path": "view.params.selected"
          },
          "type": "property"
        }
      },
      "props.style.backgroundColor": {
        "binding": {
          "config": {
            "expression": "if({this.custom.selected},\u0027--neutral-100\u0027,\u0027--neutral-10\u0027)"
          },
          "type": "expr"
        }
      },
      "props.style.cursor": {
        "binding": {
          "config": {
            "expression": "if({this.custom.selected},\u0027not-allowed\u0027,\u0027pointer\u0027)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "alignContent": "flex-start",
      "direction": "column",
      "justify": "center",
      "style": {
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}