{
  "custom": {},
  "params": {
    "selection": "Dashboard"
  },
  "propConfig": {
    "params.key": {
      "paramDirection": "input"
    },
    "params.s": {
      "paramDirection": "input"
    },
    "params.sele": {
      "paramDirection": "input"
    },
    "params.select": {
      "paramDirection": "input"
    },
    "params.selection": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 1080,
      "width": 220
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "SiteName"
            },
            "position": {
              "basis": "50px",
              "shrink": 0
            },
            "props": {
              "style": {
                "textAlign": "center"
              },
              "text": "Water / Wastewater Demo"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Image"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "source": "/system/images/logo_ignition_bw.png",
              "style": {
                "textAlign": "center"
              }
            },
            "type": "ia.display.image"
          }
        ],
        "meta": {
          "name": "Branding"
        },
        "position": {
          "basis": "140px",
          "shrink": 0
        },
        "propConfig": {
          "props.style.background": {
            "binding": {
              "config": {
                "path": "session.custom.hmi.headerBackground"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "justify": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "MenuTree"
        },
        "position": {
          "basis": "250px",
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "custom.currentWindow": {
            "binding": {
              "config": {
                "path": "view.params.selection"
              },
              "transforms": [
                {
                  "code": "\tunselected \u003d \u0027material/radio_button_unchecked\u0027\n\tselected \u003d \u0027material/radio_button_checked\u0027\n\tfor i in range(1, len(self.props.items)):\n\t\tself.props.items[i][\u0027label\u0027][\u0027icon\u0027][\u0027path\u0027] \u003d selected if value \u003d\u003d self.props.items[i][\u0027label\u0027][\u0027text\u0027] else unselected\n\treturn value",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.headerStyle.background": {
            "binding": {
              "config": {
                "path": "session.custom.hmi.background"
              },
              "type": "property"
            }
          },
          "props.itemStyle.background": {
            "binding": {
              "config": {
                "path": "session.custom.hmi.background"
              },
              "type": "property"
            }
          },
          "props.style.backgroundColor": {
            "binding": {
              "config": {
                "path": "session.custom.hmi.background"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "backActionText": "Back",
          "items": [
            {
              "items": [],
              "label": {
                "icon": {
                  "path": ""
                },
                "path": "material/radio_button_unchecked",
                "text": "Ignition 8.0 Demo"
              },
              "showHeader": true,
              "target": "/"
            },
            {
              "items": [],
              "label": {
                "icon": {
                  "path": "material/radio_button_checked"
                },
                "path": "material/radio_button_unchecked",
                "text": "Dashboard"
              },
              "navIcon": {
                "path": ""
              },
              "showHeader": true,
              "target": "/apps/water/Dashboard"
            },
            {
              "items": [],
              "label": {
                "icon": {
                  "path": "material/radio_button_unchecked"
                },
                "path": "material/radio_button_unchecked",
                "text": "Overview"
              },
              "navIcon": {
                "path": ""
              },
              "showHeader": true,
              "target": "/apps/water/Overview"
            },
            {
              "items": [],
              "label": {
                "icon": {
                  "path": "material/radio_button_unchecked"
                },
                "path": "material/radio_button_unchecked",
                "text": "Chem Feed"
              },
              "navIcon": {
                "path": ""
              },
              "showHeader": true,
              "target": "/apps/water/ChemFeed"
            },
            {
              "items": [],
              "label": {
                "icon": {
                  "path": "material/radio_button_unchecked"
                },
                "path": "material/radio_button_unchecked",
                "text": "Filters"
              },
              "navIcon": {
                "path": ""
              },
              "showHeader": true,
              "target": "/apps/water/Filters"
            }
          ],
          "style": {
            "margin": "5px 5px 0px 5px"
          }
        },
        "type": "ia.navigation.menutree"
      },
      {
        "custom": {
          "states": [
            "ActiveAcked",
            "ActiveUnacked"
          ]
        },
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "basis": "800px",
          "grow": 1
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "expression": "now(2000)"
              },
              "transforms": [
                {
                  "code": "\treturn project.alarming.getAlarms(self, value, \u0027water\u0027)",
                  "type": "script"
                }
              ],
              "type": "expr"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementStyle": {
            "flex": "0 0 auto"
          },
          "path": "Apps/Water/_AlarmMini",
          "style": {
            "backgroundColor": "rgba(250,250,250,1)",
            "margin": "0px 5px 5px 5px"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.background": {
        "binding": {
          "config": {
            "path": "session.custom.hmi.headerBackground"
          },
          "type": "property"
        }
      },
      "props.style.borderRight": {
        "binding": {
          "config": {
            "path": "session.custom.hmi.borderColor"
          },
          "transforms": [
            {
              "expression": "\"2px solid \" + {value}",
              "type": "expression"
            }
          ],
          "type": "property"
        }
      }
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}