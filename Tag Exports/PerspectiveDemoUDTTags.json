                {
                  "eventid": "valueChanged",
                  "script": "\tdef doInBackground():\n\t\timport traceback\n\t\ttopTagPath \u003d \"/\".join(tagPath.split(\"/\")[:-2])\n\t\ttagValues \u003d system.tag.readBlocking([\"%s/Poll/Running\" % topTagPath, \"%s/Poll/Hostname\" % topTagPath, \"%s/Poll/XPort\" % topTagPath, \"%s/DeviceInfo/VendorId\" % topTagPath])\n\t\trunning \u003d tagValues[0].value\n\t\thostname \u003d tagValues[1].value\n\t\txport \u003d tagValues[2].value\n\t\tvendorId \u003d tagValues[3].value\n\t\tlog \u003d system.util.getLogger(\"IFM\")\n\t\t\n\t\tif not running:\n\t\t\tsystem.tag.writeBlocking([\"%s/Poll/Running\" % topTagPath], [True])\n\t\t\n\t\t\terror \u003d None\t\n\t\t\ttry:\n\t\t\t\turl \u003d hostname\n\t\t\t\t\n\t\t\t\t# Get device info if not set\n\t\t\t\tif vendorId is None:\n\t\t\t\t\tpostData \u003d {\n\t\t\t\t\t\t\"code\":\"request\",\n\t\t\t\t\t\t\"cid\":-1,\n\t\t\t\t\t\t\"adr\":\"/iolinkmaster/port[%s]/iolinkdevice/vendorid/getdata\" % xport\n\t\t\t\t\t}\n\t\t\t\t\tpostData \u003d system.util.jsonEncode(postData)\n\t\t\t\t\tres \u003d system.net.httpPost(url\u003durl, contentType\u003d\"application/json\", postData\u003dpostData)\n\t\t\t\t\tres \u003d system.util.jsonDecode(res)\n\t\t\t\t\tvendorId \u003d res[\"data\"][\"value\"]\n\t\t\t\t\t\n\t\t\t\t\tpostData \u003d {\n\t\t\t\t\t\t\"code\":\"request\",\n\t\t\t\t\t\t\"cid\":-1,\n\t\t\t\t\t\t\"adr\":\"/iolinkmaster/port[%s]/iolinkdevice/deviceid/getdata\" % xport\n\t\t\t\t\t}\n\t\t\t\t\tpostData \u003d system.util.jsonEncode(postData)\n\t\t\t\t\tres \u003d system.net.httpPost(url\u003durl, contentType\u003d\"application/json\", postData\u003dpostData)\n\t\t\t\t\tres \u003d system.util.jsonDecode(res)\n\t\t\t\t\tdeviceId \u003d res[\"data\"][\"value\"]\n\t\t\t\t\t\n\t\t\t\t\tpostData \u003d {\n\t\t\t\t\t\t\"code\":\"request\",\n\t\t\t\t\t\t\"cid\":-1,\n\t\t\t\t\t\t\"adr\":\"/iolinkmaster/port[%s]/iolinkdevice/productname/getdata\" % xport\n\t\t\t\t\t}\n\t\t\t\t\tpostData \u003d system.util.jsonEncode(postData)\n\t\t\t\t\tres \u003d system.net.httpPost(url\u003durl, contentType\u003d\"application/json\", postData\u003dpostData)\n\t\t\t\t\tres \u003d system.util.jsonDecode(res)\n\t\t\t\t\tproductName \u003d res[\"data\"][\"value\"]\n\t\t\t\t\t\n\t\t\t\t\tpostData \u003d {\n\t\t\t\t\t\t\"code\":\"request\",\n\t\t\t\t\t\t\"cid\":-1,\n\t\t\t\t\t\t\"adr\":\"/iolinkmaster/port[%s]/iolinkdevice/serial/getdata\" % xport\n\t\t\t\t\t}\n\t\t\t\t\tpostData \u003d system.util.jsonEncode(postData)\n\t\t\t\t\tres \u003d system.net.httpPost(url\u003durl, contentType\u003d\"application/json\", postData\u003dpostData)\n\t\t\t\t\tres \u003d system.util.jsonDecode(res)\n\t\t\t\t\tserial \u003d res[\"data\"][\"value\"]\n\t\t\t\t\t\n\t\t\t\t\tsystem.tag.writeBlocking([\"%s/DeviceInfo/VendorId\" % topTagPath, \"%s/DeviceInfo/DeviceId\" % topTagPath, \"%s/DeviceInfo/ProductName\" % topTagPath, \"%s/DeviceInfo/Serial\" % topTagPath], [vendorId, deviceId, productName, serial])\n\t\t\t\t\n\t\t\t\tpostData \u003d {\n\t\t\t\t\t\"code\":\"request\",\n\t\t\t\t\t\"cid\":-1,\n\t\t\t\t\t\"adr\":\"/iolinkmaster/port[%s]/iolinkdevice/status/getdata\" % xport\n\t\t\t\t}\n\t\t\t\tpostData \u003d system.util.jsonEncode(postData)\n\t\t\t\tres \u003d system.net.httpPost(url\u003durl, contentType\u003d\"application/json\", postData\u003dpostData)\n\t\t\t\tres \u003d system.util.jsonDecode(res)\n\t\t\t\tstatus \u003d res[\"data\"][\"value\"]\n\t\t\t\t\n\t\t\t\tpostData \u003d {\n\t\t\t\t\t\"code\":\"request\",\n\t\t\t\t\t\"cid\":-1,\n\t\t\t\t\t\"adr\":\"/iolinkmaster/port[%s]/iolinkdevice/pdin/getdata\" % xport\n\t\t\t\t}\n\t\t\t\tpostData \u003d system.util.jsonEncode(postData)\n\t\t\t\tres \u003d system.net.httpPost(url\u003durl, contentType\u003d\"application/json\", postData\u003dpostData)\n\t\t\t\tres \u003d system.util.jsonDecode(res)\n\t\t\t\tdataValue \u003d res[\"data\"][\"value\"]\n\t\t\t\t\n\t\t\t\tsystem.tag.writeBlocking([\"%s/Poll/PortStatus\" % topTagPath, \"%s/Poll/PDIN\" % topTagPath], [status, dataValue])\n\t\t\texcept:\n\t\t\t\terror \u003d traceback.format_exc()\n\t\t\t\n\t\t\tsystem.tag.writeBlocking([\"%s/Poll/Running\" % topTagPath, \"%s/Poll/Status\" % topTagPath, \"%s/Poll/Error\" % topTagPath], [False, \"failed\" if error is not None else \"success\", error])\n\t\t\tif error is None:\n\t\t\t\tsystem.tag.writeBlocking([\"%s/Poll/LastExecution\" % topTagPath], [system.date.now()])\n\tsystem.util.invokeAsynchronous(doInBackground)"
                }
